#!/usr/bin/env bash

log_cleanup() {
    echo "**** (legacy-log-cleanup) $*"
}

buffer_dir="/config/.unmanic/logs/buffer"
state_file="buffer_state.json"

if [[ ! -d "${buffer_dir}" ]]; then
    log_cleanup "No log buffer directory at ${buffer_dir}; skipping legacy cleanup"
    return 0
fi

log_cleanup "Removing legacy log buffer JSON files (keeping ${state_file})"

if find "${buffer_dir}" -maxdepth 1 -type f -name '*.json' ! -name "${state_file}" -exec rm -f -- {} +; then
    log_cleanup "Legacy log buffer cleanup complete"
else
    log_cleanup "Legacy log buffer cleanup encountered errors"
fi
